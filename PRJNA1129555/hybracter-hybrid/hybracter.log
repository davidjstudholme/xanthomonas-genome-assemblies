localrule lrge:
    input: SRR30016876_1.fastq.gz
    output: hybracter-hybrid/processing/chrom_size/NCPPB_2632_lrge_estimated_chromosome_size.txt
    log: hybracter-hybrid/stderr/lrge/NCPPB_2632.log
    jobid: 31
    benchmark: hybracter-hybrid/benchmarks/lrge/NCPPB_2632.txt
    reason: Missing output files: hybracter-hybrid/processing/chrom_size/NCPPB_2632_lrge_estimated_chromosome_size.txt
    wildcards: sample=NCPPB_2632
    threads: 8
    resources: tmpdir=/tmp, mem_mb=4000, mem_mib=3815, mem=4000MB, time=00:00:05
Shell command: 
        if [[ SRR30016876_1.fastq.gz =~ \.gz$ ]]; then
        INPUT_CMD="zcat SRR30016876_1.fastq.gz"
        else
        INPUT_CMD="cat SRR30016876_1.fastq.gz"
        fi

        # Now run the awk command on the decompressed file
        if $INPUT_CMD | awk '{if (NR % 4 == 1) count++} END {exit count > 10000 ? 0 : 1}'; then
            # There are more than 10,000 reads, run lrge with defaults
            lrge -t 8 -s 42 SRR30016876_1.fastq.gz -o hybracter-hybrid/processing/chrom_size/NCPPB_2632_lrge_estimated_chromosome_size.txt
        else
            # There are less than 10,000 reads, use the all-vs-all strategy with all available reads
            lrge -t 8 -s 42 -n 10000 SRR30016876_1.fastq.gz -o hybracter-hybrid/processing/chrom_size/NCPPB_2632_lrge_estimated_chromosome_size.txt
        fi

        
