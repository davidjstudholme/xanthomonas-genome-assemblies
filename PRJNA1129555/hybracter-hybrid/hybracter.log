localrule lrge:
    input: SRR30040134_1.fastq.gz
    output: hybracter-hybrid/processing/chrom_size/NCPPB_3570_lrge_estimated_chromosome_size.txt
    log: hybracter-hybrid/stderr/lrge/NCPPB_3570.log
    jobid: 64
