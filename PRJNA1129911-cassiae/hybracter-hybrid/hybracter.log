        if $INPUT_CMD | awk '{if (NR % 4 == 1) count++} END {exit count > 10000 ? 0 : 1}'; then
            # There are more than 10,000 reads, run lrge with defaults
            lrge -t 8 -s 42 SRR30037587_1.fastq.gz -o hybracter-hybrid/processing/chrom_size/NCPPB_645_lrge_estimated_chromosome_size.txt
        else
