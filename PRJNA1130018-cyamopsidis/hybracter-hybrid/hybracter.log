Shell command: 
        if [[ SRR30037603_1.fastq.gz =~ \.gz$ ]]; then
        INPUT_CMD="zcat SRR30037603_1.fastq.gz"
        else
        INPUT_CMD="cat SRR30037603_1.fastq.gz"
        fi

        # Now run the awk command on the decompressed file
        if $INPUT_CMD | awk '{if (NR % 4 == 1) count++} END {exit count > 10000 ? 0 : 1}'; then
            # There are more than 10,000 reads, run lrge with defaults
            lrge -t 8 -s 42 SRR30037603_1.fastq.gz -o hybracter-hybrid/processing/chrom_size/NCPPB_3204_lrge_estimated_chromosome_size.txt
        else
            # There are less than 10,000 reads, use the all-vs-all strategy with all available reads
            lrge -t 8 -s 42 -n 10000 SRR30037603_1.fastq.gz -o hybracter-hybrid/processing/chrom_size/NCPPB_3204_lrge_estimated_chromosome_size.txt
        fi

        
