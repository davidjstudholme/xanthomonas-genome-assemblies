    reason: Missing output files: hybracter-hybrid/processing/chrom_size/WHRI_6066_lrge_estimated_chromosome_size.txt
    wildcards: sample=WHRI_6066
    threads: 8
    resources: tmpdir=/tmp, mem_mb=4000, mem_mib=3815, mem=4000MB, time=00:00:05
Shell command: 
        if [[ SRR27397679_1.fastq.gz =~ \.gz$ ]]; then
        INPUT_CMD="zcat SRR27397679_1.fastq.gz"
        else
        INPUT_CMD="cat SRR27397679_1.fastq.gz"
        fi

        # Now run the awk command on the decompressed file
        if $INPUT_CMD | awk '{if (NR % 4 == 1) count++} END {exit count > 10000 ? 0 : 1}'; then
            # There are more than 10,000 reads, run lrge with defaults
            lrge -t 8 -s 42 SRR27397679_1.fastq.gz -o hybracter-hybrid/processing/chrom_size/WHRI_6066_lrge_estimated_chromosome_size.txt
        else
            # There are less than 10,000 reads, use the all-vs-all strategy with all available reads
            lrge -t 8 -s 42 -n 10000 SRR27397679_1.fastq.gz -o hybracter-hybrid/processing/chrom_size/WHRI_6066_lrge_estimated_chromosome_size.txt
        fi

        
