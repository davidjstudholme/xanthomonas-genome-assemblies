    input: SRR27397679_1.fastq.gz
    output: hybracter-hybrid/processing/chrom_size/WHRI_6066_lrge_estimated_chromosome_size.txt
    log: hybracter-hybrid/stderr/lrge/WHRI_6066.log
    jobid: 16
